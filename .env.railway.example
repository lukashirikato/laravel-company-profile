# ============================================================
# Template ENV untuk Railway — copy semua key ini ke
# Railway → Project → Service → Variables
# ============================================================

# App
APP_NAME="FTM Society"
APP_ENV=production
APP_KEY=
# ↑ Generate via: php artisan key:generate --show
# Lalu paste hasilnya (formatnya: base64:xxxxx...)

APP_DEBUG=false
APP_URL=https://your-app.up.railway.app
# ↑ Ganti setelah Railway kasih domain. Bisa juga pakai custom domain.

LOG_CHANNEL=stderr
LOG_LEVEL=error

# ============================================================
# DATABASE — Railway MySQL plugin auto-inject 7 var ini:
# MYSQLHOST, MYSQLPORT, MYSQLDATABASE, MYSQLUSER, MYSQLPASSWORD,
# MYSQL_URL, MYSQL_PUBLIC_URL.
# Tapi Laravel butuh DB_* — jadi kita reference (lihat catatan)
# ============================================================
DB_CONNECTION=mysql
DATABASE_URL=${{MySQL.DATABASE_URL}}
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# Cache & Session
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail (kalau pakai Gmail SMTP, ganti accordingly)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@ftmsociety.id"
MAIL_FROM_NAME="${APP_NAME}"

# Midtrans (sesuaikan dengan akun production / sandbox)
MIDTRANS_SERVER_KEY=SB-Mid-server-IwKGCeacaHJhXk70q0tNapZb
MIDTRANS_CLIENT_KEY=SB-Mid-client-fRQvKgiCIHKCIMXt
MIDTRANS_PRODUCTION=false

# Fonnte WhatsApp
FONTTE_API_TOKEN=419Erjvfp4F1ikKFPcbL

# Migrations — di-set true HANYA pertama kali deploy,
# setelah pertama berhasil ganti ke false untuk avoid double-run
RUN_MIGRATIONS=true
RUN_SEEDERS=false
